# Discurd gateway (WebSocket) service.
FROM golang:1.26-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/gateway ./cmd/gateway

FROM alpine:3.20
RUN addgroup -S discurd && adduser -S -G discurd discurd
COPY --from=builder /out/gateway /app/gateway
USER discurd
EXPOSE 8080
ENTRYPOINT ["/app/gateway"]
