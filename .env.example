# Copy to .env and adjust. Compose reads this automatically.

# --- Security (CHANGE FOR ANY NON-LOCAL DEPLOYMENT) ---
# This built-in value is DEV ONLY. Generate a real one: `openssl rand -hex 32`.
# In production (ENV=production) the services refuse to start with this value or
# any secret under 32 characters.
JWT_SECRET=dev-secret-change-me-please-0123456789abcdef
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Tokens ---
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# --- App ---
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=25

# --- Voice/Video (LiveKit) ---
# API secret must be >= 32 chars. Generate: `openssl rand -hex 32`.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_please_0123456789abcdef
# IP that LiveKit advertises in ICE candidates. 127.0.0.1 for local; set to the
# server's PUBLIC IP when deploying (media is UDP 7882 / TCP 7881, not via Traefik).
LIVEKIT_NODE_IP=127.0.0.1

# --- GIFs (Tenor) ---
# Free key from https://developers.google.com/tenor/guides/quickstart (2 min).
# Leave empty to disable the GIF picker.
TENOR_API_KEY=
TENOR_CLIENT_KEY=discurd
